{
  "name": "keytao-app",
  "private": true,
  "version": "1.2.1-alpha.31",
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "sync-version": "node scripts/sync-version.mjs",
    "fetch:librime": "scripts/fetch-librime.sh",
    "fetch:librime:all": "scripts/fetch-librime.sh --all",
    "fetch:librime:macos": "scripts/fetch-librime-macos.sh",
    "fetch:librime:ios": "scripts/fetch-librime.sh --platform ios",
    "runtime:ios": "scripts/ios-librime-runtime.sh",
    "build:ios-simulator-smoke-runtime": "scripts/build-ios-simulator-smoke-runtime.sh",
    "check:ios-ime": "scripts/verify-ios-ime.sh",
    "init:ios": "PATH=\"$PWD/.cache/bin:$PATH\" tauri ios init --ci --skip-targets-install && scripts/setup-ios-ime-xcode.rb",
    "setup:ios-ime": "scripts/setup-ios-ime-xcode.rb",
    "build:ios-librime": "scripts/build-ios-librime.sh",
    "build:ios-ffi": "scripts/build-ios-ffi.sh",
    "build:macos": "scripts/build-macos.sh",
    "build:linux": "bash scripts/build-linux.sh",
    "build:android": "tauri android build --apk --split-per-abi",
    "build:ios": "scripts/build-ios.sh",
    "fetch:librime:windows": "powershell -ExecutionPolicy Bypass -File scripts/fetch-librime-windows.ps1",
    "build:windows-ime": "powershell -ExecutionPolicy Bypass -File scripts/build-windows-ime.ps1",
    "build:windows": "powershell -ExecutionPolicy Bypass -File scripts/build-windows.ps1"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.3.1",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@uiw/react-color": "^2.10.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.11.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
