{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "rime-dict://*"
        }
      ]
    },
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$HOME/.local/share/keytao"
        },
        {
          "path": "$HOME/.local/share/keytao/**"
        },
        {
          "path": "$HOME/Library/keytao"
        },
        {
          "path": "$HOME/Library/keytao/**"
        },
        {
          "path": "$APPDATA/keytao"
        },
        {
          "path": "$APPDATA/keytao/**"
        },
        {
          "path": "$HOME/.local/share/fcitx5/rime"
        },
        {
          "path": "$HOME/.local/share/fcitx5/rime/**"
        },
        {
          "path": "$HOME/.config/ibus/rime"
        },
        {
          "path": "$HOME/.config/ibus/rime/**"
        },
        {
          "path": "$HOME/Library/Rime"
        },
        {
          "path": "$HOME/Library/Rime/**"
        },
        {
          "path": "$APPDATA/Rime"
        },
        {
          "path": "$APPDATA/Rime/**"
        }
      ]
    },
    "dialog:allow-open",
    "os:default"
  ]
}
